{
  "name": "tallify",
  "version": "1.0.0",
  "description": "Professional Accounting & ERP System - Desktop Application",
  "author": "Tallify Team",
  "license": "MIT",
  "main": "src/main/main.js",
  "homepage": "./",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "npm run bundle-python && electron-builder",
    "build-exe": "electron-packager . Tallify --platform=win32 --arch=x64 --out=dist --overwrite",
    "pack": "npm run bundle-python && electron-builder --dir",
    "dist": "npm run bundle-python && electron-builder",
    "bundle-python": "node build-scripts/bundle-python.js",
    "rebuild-python": "node build-scripts/bundle-python.js --force",
    "css:build": "tailwindcss -i ./src/renderer/styles/input.css -o ./src/renderer/styles/output.css -c ./config/tailwind.config.js",
    "css:watch": "tailwindcss -i ./src/renderer/styles/input.css -o ./src/renderer/styles/output.css -c ./config/tailwind.config.js --watch"
  },
  "dependencies": {
    "@fortawesome/fontawesome-free": "^7.2.0",
    "@reduxjs/toolkit": "^2.11.0",
    "axios": "^1.13.2",
    "dotenv": "16.4.5",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "libphonenumber-js": "^1.11.4",
    "react-redux": "^9.2.0",
    "redux": "^5.0.1",
    "redux-thunk": "^2.4.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "electron": "^39.2.0",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "tailwindcss": "^3.4.16"
  },
  "build": {
    "appId": "com.tallify.desktop",
    "productName": "Tallify",
    "copyright": "Copyright © 2025 Tallify Team",
    "asar": true,
    "removePackageScripts": true,
    "publish": [
      {
        "provider": "github",
        "owner": "gokulkumarrajagopalan",
        "repo": "FrontEnd"
      }
    ],
    "files": [
      "src/**/*",
      "assets/**/*",
      "!**/*.map",
      "!**/*.bak",
      "!**/old/**",
      "!**/__pycache__/**",
      "!**/logs/**",
      "!**/*.spec",
      "!**/reports/**"
    ],
    "directories": {
      "buildResources": "assets",
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "resources/bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Tallify",
      "uninstallDisplayName": "Tallify - Professional Accounting & ERP",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true,
      "installerSidebar": "assets/installer-sidebar.bmp",
      "license": "assets/license.txt"
    }
  }
}
